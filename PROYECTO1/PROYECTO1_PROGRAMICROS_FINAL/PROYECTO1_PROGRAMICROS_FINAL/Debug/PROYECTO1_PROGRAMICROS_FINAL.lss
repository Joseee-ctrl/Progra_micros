                                 * Autor : Jose Martinez
                                 * Descripción: Proyecto 1 programacion de microcontroladores: Reloj de 24 horas + fecha + alarma + settings 
                                 */
                                 
                                 ; ======================== VARIABLES SRAM
                                 .include "M328PDEF.inc"
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 .dseg
                                 .org SRAM_START
                                 
000100                           msL:        .byte 1
000101                           msH:        .byte 1 ;(msL y msH hacen un contador de 16 bits que llega hasta 1000 
000102                           flag_1s:    .byte 1
                                 
000103                           blinkL:     .byte 1
000104                           blinkH:     .byte 1;500 ms 
                                 
000105                           seg:        .byte 1; contador segundos
000106                           min_u:      .byte 1
000107                           min_d:      .byte 1
000108                           hour_u:     .byte 1
000109                           hour_d:     .byte 1;reservar byte minutos y hora
                                 
00010a                           day_u:      .byte 1
00010b                           day_d:      .byte 1
00010c                           month_u:    .byte 1
00010d                           month_d:    .byte 1;reservar byte variables fecha
                                 
00010e                           current:    .byte 1 ;controlar multiplexado display (que digito muestra) 
                                 
00010f                           btn_flags:  .byte 1; que boton se presiona
000110                           mode:       .byte 1
000111                           edit_digit: .byte 1 ;que digito se edita
                                 
000112                           alarm_min_u:   .byte 1
000113                           alarm_min_d:   .byte 1
000114                           alarm_hour_u:  .byte 1
000115                           alarm_hour_d:  .byte 1; byte variables alarma
                                 
000116                           alarm_active:  .byte 1
                                 
                                 .cseg
                                 .org 0x0000
000000 c021                      RJMP RESET
                                 
                                 .org 0x0006
000006 c0b9                      RJMP PCINT0_ISR ;interrupcion botones salta a ese vector
                                 
                                 .org 0x001C
00001c c0af                      RJMP TIMER_ISR ;1ms
                                 
                                 TS7:
00001d 063f
00001e 4f5b
00001f 6d66
000020 077d
000021 6f7f                      .DB 0x3F,0x06,0x5B,0x4F,0x66,0x6D,0x7D,0x07,0x7F,0x6F; tabla display
                                 
                                 ; ========================
                                 
                                 RESET:
000022 ef0f                          LDI R16,LOW(RAMEND)
000023 bf0d                          OUT SPL,R16
000024 e008                          LDI R16,HIGH(RAMEND)
000025 bf0e                          OUT SPH,R16
                                 	; Deshabilitar USART
000026 e000                      	LDI R16, 0x00
000027 9300 00c1                 	STS UCSR0B, R16
                                 
000029 c000                          RJMP SETUP; inicializar stack
                                 
                                 ; =========================================
                                 SETUP:
00002a 2411                          CLR R1
                                 ; segmentos
00002b ef0f                          LDI R16,0b11111111
00002c b90a                          OUT DDRD,R16
00002d 2700                          CLR R16
00002e b90b                          OUT PORTD,R16
                                 ; PC1–PC5 salida
00002f e30e                          LDI R16,0b00111110
000030 b907                          OUT DDRC,R16
000031 2700                          CLR R16
000032 b908                          OUT PORTC,R16
                                 ; PB4 y PB5 salida (LED fecha + buzzer)
000033 e300                      	LDI R16,0b00110000
000034 b904                      	OUT DDRB,R16
                                 ; LED hora PC0
000035 9a38                      	SBI DDRC,0
                                 ; LED alarma PD7
000036 9a57                      	SBI DDRD,7
                                 ; pullups botones
000037 e00f                      	LDI R16,0b00001111
000038 b905                      	OUT PORTB,R16
                                 ; configurar interrupciones PCINT
000039 e001                          LDI R16,(1<<PCIE0); habilitar
00003a 9300 0068                     STS PCICR,R16
00003c e00f                          LDI R16,0b00001111
00003d 9300 006b                     STS PCMSK0,R16;mascara pines especificos activen interrupcion 
                                 ; limpiar RAM 
                                 ;hora (empezar en 0)
00003f 2700                          CLR R16
000040 9300 0100                     STS msL,R16
000042 9300 0101                     STS msH,R16
000044 9300 0102                     STS flag_1s,R16
000046 9300 0103                     STS blinkL,R16
000048 9300 0104                     STS blinkH,R16
00004a 9300 0105                     STS seg,R16
00004c 9300 0106                     STS min_u,R16
00004e 9300 0107                     STS min_d,R16
000050 9300 0108                     STS hour_u,R16
000052 9300 0109                     STS hour_d,R16
000054 9300 010e                     STS current,R16
000056 9300 010f                     STS btn_flags,R16
000058 9300 0110                     STS mode,R16
00005a 9300 0111                     STS edit_digit,R16
                                 ; FECHA (empezar en 01/01)
00005c 2700                      	CLR R16
00005d 9300 010a                 	STS day_u,R16
00005f 9300 010b                 	STS day_d,R16
000061 9300 010c                 	STS month_u,R16
000063 9300 010d                 	STS month_d,R16
000065 e001                      	LDI R16,1
000066 9300 010a                 	STS day_u,R16
000068 9300 010c                 	STS month_u,R16
                                 ;ALARMA(empezar 23:59)
00006a e009                      	LDI R16,9
00006b 9300 0112                 	STS alarm_min_u,R16
00006d e005                      	LDI R16,5
00006e 9300 0113                 	STS alarm_min_d,R16
000070 e003                      	LDI R16,3
000071 9300 0114                 	STS alarm_hour_u,R16
000073 e002                      	LDI R16,2
000074 9300 0115                 	STS alarm_hour_d,R16
000076 2700                      	CLR R16
000077 9300 0116                 	STS alarm_active,R16
                                 ; CONFIGURACION TIMER0 (1ms)(frecuencia 16MHz)
000079 e002                          LDI R16,(1<<WGM01)
00007a bd04                          OUT TCCR0A,R16; modo CTC
00007b e003                          LDI R16,(1<<CS01)|(1<<CS00)
00007c bd05                          OUT TCCR0B,R16; prescaler de 64
00007d ef09                          LDI R16,249; valor de comparacion OCR0A
00007e bd07                          OUT OCR0A,R16
00007f e002                          LDI R16,(1<<OCIE0A)
000080 9300 006e                     STS TIMSK0,R16; habilitar interrupcion por comparacion
000082 d0e3                      	RCALL UPDATE_MODE_LEDS
                                 
000083 9478                          SEI; interrupciones globales
                                 
                                 ; ========================================= MAIN LOOP
                                 MAIN:
                                 ; boton presionado?
000084 9100 010f                     LDS R16,btn_flags
000086 3000                          CPI R16,0
000087 f159                          BREQ CHECK_CLOCK
                                 ; MODE (PB0)
000088 ff00                          SBRS R16,0
000089 c006                          RJMP CHECK_SETTINGS; bloquear MODE si estamos editando
00008a 9110 0111                     LDS R17,edit_digit
00008c 3010                          CPI R17,0
00008d f511                          BRNE CLEAR_BTN
00008e d09d                          RCALL CHANGE_MODE; rutina cambiar modos
00008f c020                          RJMP CLEAR_BTN; limpiar flags boton 
                                 
                                 CHECK_SETTINGS: ;(PB1)
000090 ff01                          SBRS R16,1
000091 c002                          RJMP CHECK_UP; si no estoy presionando (no cambio digito) veo mi up
000092 d0a6                          RCALL NEXT_EDIT; cambiar el digito que estoy editando
000093 c01c                          RJMP CLEAR_BTN
                                 
                                 CHECK_UP: ; UP (PB2)
000094 ff02                      	SBRS R16,2
000095 c00e                      	RJMP CHECK_DOWN ; si no esta presionado reviso down
000096 9110 0116                 	LDS R17,alarm_active
000098 3011                      	CPI R17,1 ; verificar si la alarma esta activa
000099 f441                      	BRNE DO_UP
00009a 9120 0111                 	LDS R18,edit_digit
00009c 3020                      	CPI R18,0 ; si no estoy editando se puede apagar la alarma
00009d f421                      	BRNE DO_UP
00009e 2711                      	CLR R17
00009f 9310 0116                 	STS alarm_active,R17 ; apagar alarma
0000a1 982d                      	CBI PORTB,5
                                 
                                 DO_UP:
0000a2 d223                      	RCALL INC_DIGIT; rutina de incrementar 
0000a3 c00c                      	RJMP CLEAR_BTN
                                 
                                 CHECK_DOWN:; DOWN (PB3)
0000a4 ff03                      	SBRS R16,3
0000a5 c00a                      	RJMP CLEAR_BTN
0000a6 9110 0116                 	LDS R17,alarm_active
0000a8 3011                      	CPI R17,1
0000a9 f421                      	BRNE DO_DOWN
0000aa 2711                      	CLR R17
0000ab 9310 0116                 	STS alarm_active,R17
0000ad 982d                      	CBI PORTB,5
                                 
                                 DO_DOWN:
0000ae d29e                      	RCALL DEC_DIGIT
0000af c000                      	RJMP CLEAR_BTN
                                 
                                 CLEAR_BTN:
0000b0 2700                          CLR R16
0000b1 9300 010f                     STS btn_flags,R16
                                 
                                 CHECK_CLOCK:
0000b3 9100 0102                     LDS R16,flag_1s; 1000 ms (ISR)
0000b5 3000                          CPI R16,0
0000b6 f269                          BREQ MAIN; revisar si paso 1s (flag de ISR timer)
0000b7 2700                          CLR R16
0000b8 9300 0102                     STS flag_1s,R16; poner flag en 0 (solo entra hasta que se vuelva a activar)
0000ba 9110 0111                     LDS R17,edit_digit
0000bc 3010                          CPI R17,0
0000bd f631                          BRNE MAIN; si estoy editando no actualizo reloj
0000be d112                          RCALL UPDATE_CLOCK
0000bf cfc4                          RJMP MAIN
                                 
                                 ; ========================================= INTERRUPCIONES
                                 PCINT0_ISR: ; interrupcion botones
0000c0 930f                          PUSH R16
0000c1 b70f                          IN R16,SREG
0000c2 930f                          PUSH R16; leer SREG y guardar registros en la pila 
0000c3 b103                          IN R16,PINB
0000c4 9500                          COM R16; invertir lectura botones para que sea mas facil (1 presionado)
0000c5 700f                          ANDI R16,0b00001111; pines
0000c6 9300 010f                     STS btn_flags,R16
0000c8 910f                          POP R16
0000c9 bf0f                          OUT SREG,R16
0000ca 910f                          POP R16
0000cb 9518                          RETI; volver de la interrupcion 
                                 
                                 TIMER_ISR:; interrupcion timer
0000cc 930f                          PUSH R16
0000cd 931f                          PUSH R17
0000ce b71f                          IN R17,SREG
0000cf 931f                          PUSH R17
                                 ; multiplexado
0000d0 9842                          CBI PORTC,2
0000d1 9843                          CBI PORTC,3
0000d2 9844                          CBI PORTC,4
0000d3 9845                          CBI PORTC,5
0000d4 9100 010e                     LDS R16,current; que digito muestro
0000d6 3000                          CPI R16,0
0000d7 f029                          BREQ SHOW_DH
0000d8 3001                          CPI R16,1
0000d9 f031                          BREQ SHOW_UH
0000da 3002                          CPI R16,2
0000db f039                          BREQ SHOW_DM
0000dc c009                          RJMP SHOW_UM
                                 
                                 SHOW_DH:
0000dd d099                          RCALL LOAD_DH
0000de 9a42                          SBI PORTC,2; activar pin dh
0000df c008                          RJMP NEXT_DIG; rutina actualizar digito
                                 SHOW_UH:
0000e0 d0a6                          RCALL LOAD_UH
0000e1 9a43                          SBI PORTC,3
0000e2 c005                          RJMP NEXT_DIG
                                 SHOW_DM:
0000e3 d0b3                          RCALL LOAD_DM
0000e4 9a44                          SBI PORTC,4
0000e5 c002                          RJMP NEXT_DIG
                                 SHOW_UM:
0000e6 d0c0                          RCALL LOAD_UM
0000e7 9a45                          SBI PORTC,5
                                 
                                 NEXT_DIG:
0000e8 9100 010e                     LDS R16,current; incrementa current (para variar que digito se muestra "engańar al ojo")
0000ea 9503                          INC R16
0000eb 3004                          CPI R16,4
0000ec f008                          BRLO SAVE_CUR
0000ed 2700                          CLR R16; reiniciar en 0
                                 SAVE_CUR:
0000ee 9300 010e                     STS current,R16
0000f0 9100 0100                     LDS R16,msL; cada vez que se ejecuta timer incremento low
0000f2 9503                          INC R16
0000f3 9300 0100                     STS msL,R16
0000f5 f429                          BRNE CHECK_SECOND
0000f6 9100 0101                     LDS R16,msH; si ya llego al maximo msL voy a high
0000f8 9503                          INC R16
0000f9 9300 0101                     STS msH,R16
                                 
                                 CHECK_SECOND:; comprobar 1s
0000fb 9100 0101                     LDS R16,msH
0000fd 3003                          CPI R16,3
0000fe f461                          BRNE CHECK_BLINK
0000ff 9100 0100                     LDS R16,msL
000101 3e08                          CPI R16,232
000102 f441                          BRNE CHECK_BLINK; revisar high y low
000103 2700                          CLR R16
000104 9300 0100                     STS msL,R16
000106 9300 0101                     STS msH,R16
000108 e001                          LDI R16,1
000109 9300 0102                     STS flag_1s,R16; limpiar todo 
                                 
                                 CHECK_BLINK: ; blink 500ms
00010b 9100 0103                     LDS R16,blinkL
00010d 9503                          INC R16
00010e 9300 0103                     STS blinkL,R16
000110 f429                          BRNE CHECK_BLINK2; si blink no se pasa vamos a checkblink2
000111 9100 0104                     LDS R16,blinkH
000113 9503                          INC R16
000114 9300 0104                     STS blinkH,R16 ;si no sumamos a blinkH
                                 
                                 CHECK_BLINK2:; Puntos de hora (PC1)
000116 9100 0104                     LDS R16,blinkH
000118 3001                          CPI R16,1
000119 f469                          BRNE END_ISR
00011a 9100 0103                     LDS R16,blinkL
00011c 3f04                          CPI R16,244
00011d f449                          BRNE END_ISR
00011e 2700                          CLR R16
00011f 9300 0103                     STS blinkL,R16
000121 9300 0104                     STS blinkH,R16
000123 b108                          IN R16,PORTC
000124 e012                          LDI R17,(1<<PC1); mascara solo ese bit
000125 2701                          EOR R16,R17; encender o apagar (OR)
000126 b908                          OUT PORTC,R16; 500 ms (blinkL 244 y blinkH 1) y reiniciar
                                 
                                 END_ISR:;restaurar registros
000127 911f                          POP R17;SREG
000128 bf1f                          OUT SREG,R17
000129 911f                          POP R17;ISR
00012a 910f                          POP R16;ISR (current, msLH,blink)
00012b 9518                          RETI
                                 
                                 ; ========================================= SUBRUTINAS DE MODO
                                 CHANGE_MODE:
00012c 9100 0110                     LDS R16,mode; valor actual (hora,fecha o alarma)
00012e 9503                          INC R16; siguiente modo
00012f 3003                          CPI R16,3; 1-2-3-1
000130 f008                          BRLO SAVE_MODE
000131 2700                          CLR R16
                                 SAVE_MODE:
000132 9300 0110                     STS mode,R16
000134 2700                          CLR R16
000135 9300 0111                     STS edit_digit,R16; reiniciar digito a editar (cada modo tiene sus digitos)
000137 d02e                          RCALL UPDATE_MODE_LEDS
000138 9508                          RET
                                 
                                 ;cargar digito que se esta editando incrementar digito y pasar al siguiente
                                 NEXT_EDIT:
000139 9100 0110                 	LDS R16,mode
00013b 3000                      	CPI R16,0
00013c f071                      	BREQ NEXT_EDIT_TIME
00013d 3001                      	CPI R16,1
00013e f0a9                      	BREQ NEXT_EDIT_DATE
00013f 3002                      	CPI R16,2
000140 f009                      	BREQ NEXT_EDIT_ALARM
000141 c023                      	RJMP EXIT_EDIT
                                 NEXT_EDIT_ALARM:
000142 9100 0111                 	LDS R16,edit_digit
000144 9503                      	INC R16
000145 3005                      	CPI R16,5
000146 f008                      	BRLO SAVE_EDIT_ALARM
000147 2700                      	CLR R16
                                 SAVE_EDIT_ALARM:
000148 9300 0111                 	STS edit_digit,R16
00014a c011                      	RJMP RESET_BLINK
                                 NEXT_EDIT_TIME:
00014b 9100 0111                     LDS R16,edit_digit
00014d 9503                          INC R16
00014e 3005                          CPI R16,5
00014f f008                          BRLO SAVE_EDIT_TIME
000150 2700                          CLR R16
                                 SAVE_EDIT_TIME:
000151 9300 0111                     STS edit_digit,R16
000153 c008                          RJMP RESET_BLINK
                                 NEXT_EDIT_DATE:
000154 9100 0111                     LDS R16,edit_digit
000156 9503                          INC R16
000157 3005                          CPI R16,5
000158 f008                          BRLO SAVE_EDIT_DATE
000159 2700                          CLR R16
                                 SAVE_EDIT_DATE:
00015a 9300 0111                     STS edit_digit,R16
                                 
                                 RESET_BLINK:; reiniciar que digito se esta mostrando
00015c e013                          LDI R17,3
00015d 9310 010e                     STS current,R17
                                     ; reiniciar blink
00015f 2711                          CLR R17
000160 9310 0103                     STS blinkL,R17
000162 e011                          LDI R17,1
000163 9310 0104                     STS blinkH,R17
                                 EXIT_EDIT:
000165 9508                          RET
                                 
                                 UPDATE_MODE_LEDS:; LEDS INDICADORES DE MODO 
000166 9840                          CBI PORTC,0; apagar todos
000167 982c                          CBI PORTB,4
000168 985f                          CBI PORTD,7
000169 9100 0110                     LDS R16,mode; modo actual
                                 ; modo hora
00016b 3000                          CPI R16,0
00016c f411                          BRNE CHECK_LED_DATE
00016d 9a40                          SBI PORTC,0
00016e 9508                          RET
                                 CHECK_LED_DATE:; modo fecha
00016f 3001                          CPI R16,1
000170 f411                          BRNE CHECK_LED_ALARM
000171 9a2c                          SBI PORTB,4
000172 9508                          RET
                                 CHECK_LED_ALARM:; modo alarma
000173 3002                          CPI R16,2
000174 f409                          BRNE LED_EXIT
000175 9a5f                          SBI PORTD,7
                                 LED_EXIT:
000176 9508                          RET
                                 
                                 ; ========================================= SUBRUTINAS DE DISPLAY
                                 
                                 ;LOAD lee el modo luego salta a la rutina que muestra cada valor de digito segun el modo
                                 LOAD_DH:
000177 9100 0110                     LDS R16,mode
000179 3000                          CPI R16,0
00017a f019                          BREQ TIME_DH
00017b 3001                          CPI R16,1
00017c f021                          BREQ DATE_DH
00017d c006                          RJMP ALARM_DH
                                 TIME_DH:
00017e 9100 0109                     LDS R16,hour_d
000180 c036                          RJMP DISPLAY_DIG
                                 DATE_DH:
000181 9100 010b                     LDS R16,day_d
000183 c033                          RJMP DISPLAY_DIG
                                 ALARM_DH:
000184 9100 0115                     LDS R16,alarm_hour_d
000186 c030                          RJMP DISPLAY_DIG
                                 LOAD_UH:
000187 9100 0110                     LDS R16,mode
000189 3000                          CPI R16,0
00018a f019                          BREQ TIME_UH
00018b 3001                          CPI R16,1
00018c f021                          BREQ DATE_UH
00018d c006                          RJMP ALARM_UH
                                 TIME_UH:
00018e 9100 0108                     LDS R16,hour_u
000190 c026                          RJMP DISPLAY_DIG
                                 DATE_UH:
000191 9100 010a                     LDS R16,day_u
000193 c023                          RJMP DISPLAY_DIG
                                 ALARM_UH:
000194 9100 0114                     LDS R16,alarm_hour_u
000196 c020                          RJMP DISPLAY_DIG
                                 LOAD_DM:
000197 9100 0110                     LDS R16,mode
000199 3000                          CPI R16,0
00019a f019                          BREQ TIME_DM
00019b 3001                          CPI R16,1
00019c f021                          BREQ DATE_DM
00019d c006                          RJMP ALARM_DM
                                 TIME_DM:
00019e 9100 0107                     LDS R16,min_d
0001a0 c016                          RJMP DISPLAY_DIG
                                 DATE_DM:
0001a1 9100 010d                     LDS R16,month_d
0001a3 c013                          RJMP DISPLAY_DIG
                                 ALARM_DM:
0001a4 9100 0113                     LDS R16,alarm_min_d
0001a6 c010                          RJMP DISPLAY_DIG
                                 LOAD_UM:
0001a7 9100 0110                     LDS R16,mode
0001a9 3000                          CPI R16,0
0001aa f019                          BREQ TIME_UM
0001ab 3001                          CPI R16,1
0001ac f021                          BREQ DATE_UM
0001ad c006                          RJMP ALARM_UM
                                 TIME_UM:
0001ae 9100 0106                     LDS R16,min_u
0001b0 c006                          RJMP DISPLAY_DIG
                                 DATE_UM:
0001b1 9100 010c                     LDS R16,month_u
0001b3 c003                          RJMP DISPLAY_DIG
                                 ALARM_UM:
0001b4 9100 0112                     LDS R16,alarm_min_u
0001b6 c000                          RJMP DISPLAY_DIG
                                 
                                 ; VISUALIZACION DISPLAY NORMAL O EDITANDO (PARPADEAR)
                                 DISPLAY_DIG:
0001b7 931f                          PUSH R17
0001b8 932f                          PUSH R18; guardar registros que voy a usar para no alterar main o ISR
0001b9 9120 0111                     LDS R18,edit_digit
0001bb 3020                          CPI R18,0
0001bc f049                          BREQ SHOW_NORMAL; si no estoy editando voy a mostrar el numero sin parpadear
0001bd 9110 010e                     LDS R17,current; que digito esta activo en el multiplexado?
0001bf 9513                          INC R17
0001c0 1712                          CP R17,R18; comparar current con el digito que se esta editando
0001c1 f421                          BRNE SHOW_NORMAL; si no es el mismo numero (los demas se muestran normal)
0001c2 9110 0104                     LDS R17,blinkH; cargar valor (500ms)
0001c4 3010                          CPI R17,0
0001c5 f021                          BREQ BLINK_OFF; si es 0 se apaga el digito en ese instante
                                 
                                 SHOW_NORMAL:
0001c6 d2aa                          RCALL SEG7; convertir valor 
0001c7 912f                          POP R18
0001c8 911f                          POP R17;restaurar registros
0001c9 9508                          RET
                                 
                                 BLINK_OFF:; apagar digito para parpadeo (enciende de nuevo en mi ISR)
0001ca 2700                          CLR R16
0001cb b11b                      	IN  R17,PORTD
0001cc 7810                      	ANDI R17,0b10000000; mascara apagar todos los segmentos
0001cd b91b                      	OUT PORTD,R17
0001ce 912f                          POP R18
0001cf 911f                          POP R17
0001d0 9508                          RET
                                 
                                 ; ========================================= SUBRUTINAS DE RELOJ
                                 UPDATE_CLOCK:
0001d1 9100 0105                     LDS R16,seg
0001d3 9503                          INC R16; suma 1 seg
0001d4 330c                          CPI R16,60
0001d5 f008                          BRLO SAVE_SEC; si no llega a 60 guardo el valor y termina mi rutina
0001d6 2700                          CLR R16
                                 ;si llega a 60 se reinician, incremento minutos y guardo mis valores (sucesivamente con horas)
                                 SAVE_SEC:
0001d7 9300 0105                     STS seg,R16
0001d9 3000                          CPI R16,0
0001da f5c1                          BRNE EXIT_UPDATE
0001db 9100 0106                     LDS R16,min_u
0001dd 9503                          INC R16
0001de 300a                          CPI R16,10
0001df f008                          BRLO SAVE_MU
0001e0 2700                          CLR R16
                                 SAVE_MU:
0001e1 9300 0106                     STS min_u,R16
0001e3 3000                          CPI R16,0
0001e4 f571                          BRNE EXIT_UPDATE
0001e5 9100 0107                     LDS R16,min_d
0001e7 9503                          INC R16
0001e8 3006                          CPI R16,6
0001e9 f008                          BRLO SAVE_MD
0001ea 2700                          CLR R16
                                 SAVE_MD:
0001eb 9300 0107                     STS min_d,R16
0001ed 3000                          CPI R16,0
0001ee f521                          BRNE EXIT_UPDATE
0001ef 9100 0108                     LDS R16,hour_u
0001f1 9503                          INC R16
0001f2 300a                          CPI R16,10
0001f3 f008                          BRLO SAVE_HU
0001f4 2700                          CLR R16
                                 SAVE_HU:
0001f5 9300 0108                     STS hour_u,R16
0001f7 3000                          CPI R16,0
0001f8 f441                          BRNE CHECK_24
0001f9 9100 0109                     LDS R16,hour_d
0001fb 9503                          INC R16
0001fc 3003                          CPI R16,3
0001fd f008                          BRLO SAVE_HD
0001fe 2700                          CLR R16
                                 SAVE_HD:
0001ff 9300 0109                     STS hour_d,R16
                                 
                                 CHECK_24: ;verificar si llego a 24:00 para reiniciar
000201 9120 0111                     LDS R18,edit_digit
000203 3020                          CPI R18,0
000204 f471                          BRNE EXIT_UPDATE;no cambiar fecha si estoy editando
000205 9100 0109                     LDS R16,hour_d
000207 3002                          CPI R16,2
000208 f451                          BRNE EXIT_UPDATE
000209 9100 0108                     LDS R16,hour_u
00020b 3004                          CPI R16,4
00020c f431                          BRNE EXIT_UPDATE
00020d 2700                          CLR R16
00020e 9300 0109                     STS hour_d,R16
000210 9300 0108                     STS hour_u,R16
000212 d002                      	RCALL DATE_INCREMENT_ROUTINE
                                 
                                 EXIT_UPDATE:
000213 d08d                          RCALL CHECK_ALARM; luego de guardar valores revisar alarma
000214 9508                          RET
                                 
                                 ; ========================================= SUBRUTINAS DE FECHA
                                 
                                 DATE_INCREMENT_ROUTINE:; unidades dias y decenas icnrementar
000215 9100 010a                     LDS R16,day_u
000217 9503                          INC R16
000218 300a                          CPI R16,10
000219 f048                          BRLO DATE_SAVE_DAYU
00021a 2700                          CLR R16
00021b 9300 010a                     STS day_u,R16
00021d 9110 010b                     LDS R17,day_d
00021f 9513                          INC R17
000220 9310 010b                     STS day_d,R17
000222 c002                          RJMP DATE_CHECK_MONTH_LIMIT
                                 DATE_SAVE_DAYU:
000223 9300 010a                     STS day_u,R16
                                 
                                 DATE_CHECK_MONTH_LIMIT:
000225 d001                          RCALL DATE_VERIFY_DAY_LIMIT
000226 9508                          RET
                                 
                                 ; VERIFICAR LIMITE DE DIAS DEL MES
                                 DATE_VERIFY_DAY_LIMIT:
                                 ; evitar dia = 00
000227 9100 010b                 	LDS R16,day_d
000229 9110 010a                 	LDS R17,day_u
00022b 2b01                      	OR  R16,R17
00022c f431                      	BRNE CHECK_MONTH_ZERO
00022d e001                      	LDI R16,1
00022e 9300 010a                 	STS day_u,R16
000230 2700                      	CLR R16
000231 9300 010b                 	STS day_d,R16
                                 ; evitar mes = 00
                                 CHECK_MONTH_ZERO:
000233 9120 010d                 	LDS R18,month_d
000235 9130 010c                 	LDS R19,month_u
000237 2b23                      	OR  R18,R19
000238 f431                      	BRNE CALC_DAY
000239 e031                      	LDI R19,1
00023a 9330 010c                 	STS month_u,R19
00023c 2733                      	CLR R19
00023d 9330 010d                 	STS month_d,R19
                                 
                                 ;calcular dia (decena y unidad junto no como digito separado)
                                 CALC_DAY:
00023f 9100 010b                 	LDS R16,day_d
000241 2f20                      	MOV R18,R16
000242 0f00                      	LSL R16
000243 0f00                      	LSL R16
000244 0f00                      	LSL R16
000245 0f22                      	LSL R18; LSL multiplica x2 (lo uso para llegar a decena (*10))
000246 0f02                      	ADD R16,R18 
000247 9110 010a                 	LDS R17,day_u
000249 0f01                      	ADD R16,R17; sumamos con unidades
                                 	;ver en que mes estoy
00024a 9120 010d                 	LDS R18,month_d; (decena mes 0 o 1)
00024c 9130 010c                 	LDS R19,month_u; (unidad mes 1 a 9)
                                 
                                 ; febrero
00024e 3020                      	CPI R18,0; decena mes
00024f f421                      	BRNE CHECK_30
000250 3032                      	CPI R19,2; febrero (mes 2)
000251 f411                      	BRNE CHECK_30
000252 e14c                      	LDI R20,28; 28 dias maximo
000253 c00c                      	RJMP CHECK_LIMIT
                                 ; meses de 30 dias
                                 CHECK_30:
000254 3020                      	CPI R18,0; decena mes es 0 (meses de un digito)
000255 f449                      	BRNE MONTH_31
000256 3034                      	CPI R19,4; abril
000257 f029                      	BREQ SET_30
000258 3036                      	CPI R19,6; junio
000259 f019                      	BREQ SET_30
00025a 3039                      	CPI R19,9;septiembre
00025b f009                      	BREQ SET_30
00025c c002                      	RJMP MONTH_31; si no es alguno de esos tiene 31 dias
                                 SET_30:
00025d e14e                      	LDI R20,30
00025e c001                      	RJMP CHECK_LIMIT
                                 ; meses de 31 dias
                                 MONTH_31:
00025f e14f                      	LDI R20,31
                                 
                                 CHECK_LIMIT: ;verificar limite dependiendo de r20 cargado
000260 1704                          CP R16,R20
000261 f018                          BRLO DATE_OK; si el dia actual es menor salta a date ok
000262 f011                          BREQ DATE_OK
000263 d002                          RCALL DATE_NEXT_MONTH_ROUTINE;; si es el mismo dia no importa si no va a esta rutina
000264 dfc2                          RCALL DATE_VERIFY_DAY_LIMIT ;revalidar dia con el nuevo mes
                                 
                                 DATE_OK:
000265 9508                          RET
                                 
                                 DATE_NEXT_MONTH_ROUTINE: ;CAMBIAR DE MES
000266 e001                          LDI R16,1
000267 9300 010a                     STS day_u,R16
000269 2700                          CLR R16
00026a 9300 010b                     STS day_d,R16; reiniciar dia a 01
00026c 9100 010c                     LDS R16,month_u
00026e 9503                          INC R16
00026f 300a                          CPI R16,10
000270 f048                          BRLO SAVE_MONTH_U; incrementar unidad mes
000271 2700                          CLR R16
000272 9300 010c                     STS month_u,R16
000274 9110 010d                     LDS R17,month_d
000276 9513                          INC R17
000277 9310 010d                     STS month_d,R17; si se paso unidad mes sumar decena
000279 c017                          RJMP CHECK_YEAR_LIMIT
                                 
                                 SAVE_MONTH_U:
00027a 9300 010c                     STS month_u,R16
00027c c014                          RJMP CHECK_YEAR_LIMIT
                                 
                                 ; validar que mes este entre 01 y 12
                                 FIX_MONTH_LIMIT:
00027d 9100 010d                     LDS R16,month_d
00027f 2f20                          MOV R18,R16
000280 0f00                          LSL R16
000281 0f00                          LSL R16
000282 0f00                          LSL R16
000283 0f22                          LSL R18
000284 0f02                          ADD R16,R18
000285 9110 010c                     LDS R17,month_u
000287 0f01                          ADD R16,R17   ; R16 = mes completo
000288 300d                          CPI R16,13
000289 f030                          BRLO MONTH_OK
00028a e011                          LDI R17,1
00028b 9310 010c                     STS month_u,R17
00028d 2711                          CLR R17
00028e 9310 010d                     STS month_d,R17
                                 
                                 MONTH_OK:
000290 9508                          RET
                                 
                                 CHECK_YEAR_LIMIT:
000291 9100 010d                     LDS R16,month_d
000293 3001                          CPI R16,1
000294 f451                          BRNE END_MONTH
000295 9110 010c                     LDS R17,month_u
000297 3013                          CPI R17,3
000298 f431                          BRNE END_MONTH; si no se ha pasado de 12 termina fecha
000299 e001                          LDI R16,1
00029a 9300 010c                     STS month_u,R16
00029c 2700                          CLR R16
00029d 9300 010d                     STS month_d,R16; si no empezar en enero
                                 
                                 END_MONTH:
00029f dfdd                      	RCALL FIX_MONTH_LIMIT
0002a0 9508                          RET
                                 
                                 ; ========================================= SUBRUTINAS DE ALARMA
                                 
                                 CHECK_ALARM:
                                 ; solo revisar al inicio del minuto
0002a1 9100 0105                 	LDS R16,seg
0002a3 3000                      	CPI R16,0
0002a4 f501                      	BRNE ALARM_EXIT
                                 ; si ya está activa no volver a activarla
0002a5 9120 0116                 	LDS R18,alarm_active
0002a7 3021                      	CPI R18,1
0002a8 f0e1                      	BREQ ALARM_EXIT
                                 ; comparar hora
0002a9 9100 0109                 	LDS R16,hour_d
0002ab 9110 0115                 	LDS R17,alarm_hour_d
0002ad 1701                      	CP R16,R17
0002ae f4b1                      	BRNE ALARM_EXIT
0002af 9100 0108                 	LDS R16,hour_u
0002b1 9110 0114                 	LDS R17,alarm_hour_u
0002b3 1701                      	CP R16,R17
0002b4 f481                      	BRNE ALARM_EXIT
                                 ; comparar minutos
0002b5 9100 0107                 	LDS R16,min_d
0002b7 9110 0113                 	LDS R17,alarm_min_d
0002b9 1701                      	CP R16,R17
0002ba f451                      	BRNE ALARM_EXIT
0002bb 9100 0106                 	LDS R16,min_u
0002bd 9110 0112                 	LDS R17,alarm_min_u
0002bf 1701                      	CP R16,R17
0002c0 f421                      	BRNE ALARM_EXIT
                                 ; activar alarma (BUZZER)
0002c1 e001                      	LDI R16,1
0002c2 9300 0116                 	STS alarm_active,R16
0002c4 9a2d                      	SBI PORTB,5
                                 
                                 ALARM_EXIT:
0002c5 9508                      	RET
                                 
                                 ; ========================================= SUBRUTINAS DE INCREMENTAR 
                                 INC_DIGIT:
0002c6 9100 0110                     LDS R16,mode; veo en que modo estoy
0002c8 3000                          CPI R16,0
0002c9 f409                          BRNE CHECK_INC_DATE
0002ca c007                          RJMP INC_DIGIT_TIME
                                 CHECK_INC_DATE:
0002cb 3001                          CPI R16,1
0002cc f409                          BRNE CHECK_INC_ALARM
0002cd c046                          RJMP INC_DIGIT_DATE
                                 CHECK_INC_ALARM:
0002ce 3002                          CPI R16,2
0002cf f409                          BRNE INC_EXIT
0002d0 c10a                          RJMP INC_DIGIT_ALARM
                                 
                                 INC_EXIT:
0002d1 9508                      	RET
                                 
                                 ; INCREMENTAR HORA
                                 INC_DIGIT_TIME:
0002d2 9100 0111                 	LDS R16,edit_digit; que digito se va a incrementar
0002d4 3000                      	CPI R16,0
0002d5 f3d9                      	BREQ INC_EXIT
0002d6 3001                      	CPI R16,1
0002d7 f029                      	BREQ INC_HOUR_D
0002d8 3002                      	CPI R16,2
0002d9 f061                      	BREQ INC_HOUR_U
0002da 3003                      	CPI R16,3
0002db f0d9                      	BREQ INC_MIN_D
0002dc c023                      	RJMP INC_MIN_U
                                 INC_HOUR_D:
0002dd 9110 0109                 	LDS R17,hour_d
0002df 9513                      	INC R17
0002e0 3013                      	CPI R17,3;incrementar decena de hora
0002e1 f008                      	BRLO INC_HD_SAVE
0002e2 2711                      	CLR R17
                                 INC_HD_SAVE:
0002e3 9310 0109                 	STS hour_d,R17
0002e5 c023                      	RJMP INC_HOUR_FIX; arreglar caso especial 23 a 00
                                 INC_HOUR_U:
0002e6 9110 0108                 	LDS R17,hour_u
0002e8 9513                      	INC R17
0002e9 9120 0109                 	LDS R18,hour_d
0002eb 3022                      	CPI R18,2
0002ec f421                      	BRNE INC_HU_MAX9; si no es 2 salto 
0002ed 3014                      	CPI R17,4; si es 2 el maximo es 3 (23hrs)
0002ee f028                      	BRLO INC_HU_SAVE
0002ef 2711                      	CLR R17; si se paso pongo unidad en 0
0002f0 c003                      	RJMP INC_HU_SAVE
                                 
                                 INC_HU_MAX9:
0002f1 301a                      	CPI R17,10
0002f2 f008                      	BRLO INC_HU_SAVE
0002f3 2711                      	CLR R17
                                 INC_HU_SAVE:
0002f4 9310 0108                 	STS hour_u,R17
0002f6 9508                      	RET
                                 
                                 INC_MIN_D:
0002f7 9110 0107                 	LDS R17,min_d
0002f9 9513                      	INC R17
0002fa 3016                      	CPI R17,6
0002fb f008                      	BRLO INC_MD_SAVE
0002fc 2711                      	CLR R17
                                 	INC_MD_SAVE:
0002fd 9310 0107                 	STS min_d,R17
0002ff 9508                      	RET
                                 INC_MIN_U:
000300 9110 0106                 	LDS R17,min_u
000302 9513                      	INC R17
000303 301a                      	CPI R17,10
000304 f008                      	BRLO INC_MU_SAVE
000305 2711                      	CLR R17
                                 INC_MU_SAVE:
000306 9310 0106                 	STS min_u,R17
000308 9508                      	RET
                                 
                                 INC_HOUR_FIX:
000309 9110 0109                 	LDS R17,hour_d
00030b 3012                      	CPI R17,2
00030c f621                      	BRNE INC_EXIT
00030d 9110 0108                 	LDS R17,hour_u
00030f 3014                      	CPI R17,4
000310 f200                      	BRLO INC_EXIT
000311 e013                      	LDI R17,3
000312 9310 0108                 	STS hour_u,R17
                                 
                                 ; INCREMENTAR FECHA
                                 INC_DIGIT_DATE:
000314 9100 0111                 	LDS R16,edit_digit
000316 3000                      	CPI R16,0
000317 f409                      	BRNE INC_DATE_CHECK1
000318 cfb8                      	RJMP INC_EXIT
                                 INC_DATE_CHECK1:
000319 3001                      	CPI R16,1
00031a f409                      	BRNE INC_DATE_CHECK2
00031b c007                      	RJMP INC_DAY_D
                                 INC_DATE_CHECK2:
00031c 3002                      	CPI R16,2
00031d f409                      	BRNE INC_DATE_CHECK3
00031e c00e                      	RJMP INC_DAY_U
                                 INC_DATE_CHECK3:
00031f 3003                      	CPI R16,3
000320 f409                      	BRNE INC_DATE_CHECK4
000321 c015                      	RJMP INC_MONTH_D
                                 INC_DATE_CHECK4:
000322 c01f                      	RJMP INC_MONTH_U
                                 INC_DAY_D:
000323 9110 010b                     LDS R17,day_d
000325 9513                          INC R17
000326 3014                          CPI R17,4
000327 f008                          BRLO INC_DAY_D_SAVE
000328 2711                          CLR R17
                                 INC_DAY_D_SAVE:
000329 9310 010b                     STS day_d,R17
00032b defb                          RCALL DATE_VERIFY_DAY_LIMIT
00032c 9508                          RET
                                 INC_DAY_U:
00032d 9110 010a                     LDS R17,day_u
00032f 9513                          INC R17
000330 301a                          CPI R17,10
000331 f008                          BRLO INC_DAY_U_SAVE
000332 2711                          CLR R17
                                 INC_DAY_U_SAVE:
000333 9310 010a                     STS day_u,R17
000335 def1                          RCALL DATE_VERIFY_DAY_LIMIT
000336 9508                          RET
                                 INC_MONTH_D:
000337 9110 010d                     LDS R17,month_d
000339 9513                          INC R17
00033a 3012                          CPI R17,2
00033b f008                          BRLO INC_MONTH_D_SAVE
00033c 2711                          CLR R17
                                 INC_MONTH_D_SAVE:
00033d 9310 010d                     STS month_d,R17
00033f df3d                      	RCALL FIX_MONTH_LIMIT
000340 dee6                          RCALL DATE_VERIFY_DAY_LIMIT
000341 9508                          RET
                                 INC_MONTH_U:
000342 9110 010c                     LDS R17,month_u
000344 9513                          INC R17
000345 301a                          CPI R17,10
000346 f008                          BRLO INC_MONTH_U_SAVE
000347 2711                          CLR R17
                                 INC_MONTH_U_SAVE:
000348 9310 010c                     STS month_u,R17
00034a df32                      	RCALL FIX_MONTH_LIMIT
00034b dedb                          RCALL DATE_VERIFY_DAY_LIMIT
00034c 9508                          RET
                                 
                                 ; ========================================= SUBRUTINAS DECREMENTAR
                                 DEC_DIGIT:
00034d 9100 0110                     LDS R16,mode
00034f 3000                          CPI R16,0
000350 f409                          BRNE DEC_CHECK_DATE
000351 c007                          RJMP DEC_DIGIT_TIME
                                 DEC_CHECK_DATE:
000352 3001                          CPI R16,1
000353 f409                          BRNE DEC_CHECK_ALARM
000354 c04d                          RJMP DEC_DIGIT_DATE
                                 DEC_CHECK_ALARM:
000355 3002                          CPI R16,2
000356 f409                          BRNE DEC_EXIT_LOCAL
000357 c0cd                          RJMP DEC_DIGIT_ALARM
                                 DEC_EXIT_LOCAL:
000358 c081                          RJMP DEC_EXIT
                                 ; DECREMENTAR HORA
                                 DEC_DIGIT_TIME:
000359 9100 0111                     LDS R16,edit_digit
00035b 3000                          CPI R16,0
00035c f409                          BRNE DEC_CHECK_HD
00035d c07c                          RJMP DEC_EXIT
                                 DEC_CHECK_HD:
00035e 3001                          CPI R16,1
00035f f409                          BRNE DEC_CHECK_HU
000360 c006                          RJMP DEC_HOUR_D
                                 DEC_CHECK_HU:
000361 3002                          CPI R16,2
000362 f409                          BRNE DEC_CHECK_MD
000363 c00d                          RJMP DEC_HOUR_U
                                 DEC_CHECK_MD:
000364 3003                          CPI R16,3
000365 f529                          BRNE DEC_MIN_U
000366 c01a                          RJMP DEC_MIN_D
                                 DEC_HOUR_D:
000367 9110 0109                     LDS R17,hour_d
000369 3010                          CPI R17,0; verificar limite
00036a f411                          BRNE DEC_HD_STEP; decrementar el valor
00036b e012                          LDI R17,2
00036c c001                          RJMP DEC_HD_SAVE
                                 DEC_HD_STEP:
00036d 951a                          DEC R17
                                 DEC_HD_SAVE:
00036e 9310 0109                     STS hour_d,R17
000370 c024                          RJMP DEC_HOUR_FIX
                                 DEC_HOUR_U:
000371 9110 0108                     LDS R17,hour_u
000373 3010                          CPI R17,0
000374 f441                          BRNE DEC_HU_STEP
000375 9120 0109                     LDS R18,hour_d
000377 3022                          CPI R18,2
000378 f411                          BRNE DEC_HU_9
000379 e013                          LDI R17,3
00037a c003                          RJMP DEC_HU_SAVE
                                 DEC_HU_9:
00037b e019                          LDI R17,9
00037c c001                          RJMP DEC_HU_SAVE
                                 DEC_HU_STEP:
00037d 951a                          DEC R17
                                 DEC_HU_SAVE:
00037e 9310 0108                     STS hour_u,R17
000380 c059                          RJMP DEC_EXIT
                                 DEC_MIN_D:
000381 9110 0107                     LDS R17,min_d
000383 3010                          CPI R17,0
000384 f411                          BRNE DEC_MD_STEP
000385 e015                          LDI R17,5
000386 c001                          RJMP DEC_MD_SAVE
                                 DEC_MD_STEP:
000387 951a                          DEC R17
                                 DEC_MD_SAVE:
000388 9310 0107                     STS min_d,R17
00038a c04f                          RJMP DEC_EXIT
                                 DEC_MIN_U:
00038b 9110 0106                     LDS R17,min_u
00038d 3010                          CPI R17,0
00038e f411                          BRNE DEC_MU_STEP
